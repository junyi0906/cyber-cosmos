import { useState, useEffect, useCallback } from 'react';
import type { SocialState, Civilization, DiplomacyRelation, Alliance, Treaty, Broadcast, Vote } from '../components/Social/types';

interface UseSocialDataReturn {
  data: SocialState | null;
  loading: boolean;
  error: string | null;
  refresh: () => Promise<void>;
  updateRelation: (sourceId: string, targetId: string, type: DiplomacyRelation['type']) => Promise<void>;
  createAlliance: (name: string, leaderId: string, description: string) => Promise<void>;
  joinAlliance: (allianceId: string, civilizationId: string) => Promise<void>;
  leaveAlliance: (allianceId: string, civilizationId: string) => Promise<void>;
  proposeTreaty: (treaty: Omit<Treaty, 'id' | 'signedAt' | 'status'>) => Promise<void>;
  sendBroadcast: (broadcast: Omit<Broadcast, 'id' | 'timestamp'>) => Promise<void>;
  castVote: (voteId: string, civilizationId: string, optionId: string) => Promise<void>;
  createVote: (allianceId: string, title: string, description: string, options: { id: string; text: string }[]) => Promise<void>;
}

const API_BASE = '/api/social';

export function useSocialData(): UseSocialDataReturn {
  const [data, setData] = useState<SocialState | null>(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);

  const fetchData = useCallback(async () => {
    try {
      setLoading(true);
      setError(null);
      
      const response = await fetch(`${API_BASE}/state`);
      if (!response.ok) {
        throw new Error(`HTTP error! status: ${response.status}`);
      }
      const result = await response.json();
      setData(result);
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to fetch social data');
      setData(getMockData());
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    fetchData();
    
    const ws = new WebSocket(`ws://${window.location.host}/ws/social`);
    ws.onmessage = (event) => {
      const update = JSON.parse(event.data);
      setData(prev => prev ? { ...prev, ...update } : prev);
    };
    
    return () => ws.close();
  }, [fetchData]);

  const updateRelation = useCallback(async (sourceId: string, targetId: string, type: DiplomacyRelation['type']) => {
    try {
      await fetch(`${API_BASE}/relation`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sourceId, targetId, type })
      });
      setData(prev => {
        if (!prev) return prev;
        const relations = prev.relations.map(r => 
          r.sourceId === sourceId && r.targetId === targetId ? { ...r, type } : r
        );
        return { ...prev, relations };
      });
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to update relation');
    }
  }, []);

  const createAlliance = useCallback(async (name: string, leaderId: string, description: string) => {
    try {
      const response = await fetch(`${API_BASE}/alliance`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, leaderId, description })
      });
      const newAlliance = await response.json();
      setData(prev => prev ? { ...prev, alliances: [...prev.alliances, newAlliance] } : prev);
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to create alliance');
    }
  }, []);

  const joinAlliance = useCallback(async (allianceId: string, civilizationId: string) => {
    try {
      await fetch(`${API_BASE}/alliance/${allianceId}/join`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ civilizationId })
      });
      setData(prev => {
        if (!prev) return prev;
        const alliances = prev.alliances.map(a => {
          if (a.id === allianceId) {
            return {
              ...a,
              members: [...a.members, {
                civilizationId,
                joinedAt: Date.now(),
                role: 'member' as const,
                contribution: 0
              }]
            };
          }
          return a;
        });
        return { ...prev, alliances };
      });
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to join alliance');
    }
  }, []);

  const leaveAlliance = useCallback(async (allianceId: string, civilizationId: string) => {
    try {
      await fetch(`${API_BASE}/alliance/${allianceId}/leave`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ civilizationId })
      });
      setData(prev => {
        if (!prev) return prev;
        const alliances = prev.alliances.map(a => {
          if (a.id === allianceId) {
            return {
              ...a,
              members: a.members.filter(m => m.civilizationId !== civilizationId)
            };
          }
          return a;
        });
        return { ...prev, alliances };
      });
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to leave alliance');
    }
  }, []);

  const proposeTreaty = useCallback(async (treaty: Omit<Treaty, 'id' | 'signedAt' | 'status'>) => {
    try {
      const response = await fetch(`${API_BASE}/treaty`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(treaty)
      });
      const newTreaty = await response.json();
      setData(prev => prev ? { ...prev, treaties: [...prev.treaties, newTreaty] } : prev);
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to propose treaty');
    }
  }, []);

  const sendBroadcast = useCallback(async (broadcast: Omit<Broadcast, 'id' | 'timestamp'>) => {
    try {
      const response = await fetch(`${API_BASE}/broadcast`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(broadcast)
      });
      const newBroadcast = await response.json();
      setData(prev => prev ? { ...prev, broadcasts: [newBroadcast, ...prev.broadcasts] } : prev);
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to send broadcast');
    }
  }, []);

  const castVote = useCallback(async (voteId: string, civilizationId: string, optionId: string) => {
    try {
      await fetch(`${API_BASE}/vote/${voteId}/cast`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ civilizationId, optionId })
      });
      setData(prev => {
        if (!prev) return prev;
        const votes = prev.votes.map(v => {
          if (v.id === voteId) {
            return {
              ...v,
              votes: [...v.votes, { civilizationId, optionId, timestamp: Date.now() }]
            };
          }
          return v;
        });
        return { ...prev, votes };
      });
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to cast vote');
    }
  }, []);

  const createVote = useCallback(async (allianceId: string, title: string, description: string, options: { id: string; text: string }[]) => {
    try {
      const response = await fetch(`${API_BASE}/vote`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ allianceId, title, description, options })
      });
      const newVote = await response.json();
      setData(prev => prev ? { ...prev, votes: [...prev.votes, newVote] } : prev);
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to create vote');
    }
  }, []);

  return {
    data,
    loading,
    error,
    refresh: fetchData,
    updateRelation,
    createAlliance,
    joinAlliance,
    leaveAlliance,
    proposeTreaty,
    sendBroadcast,
    castVote,
    createVote
  };
}

