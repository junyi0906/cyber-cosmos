    { sourceId: 'civ-3', targetId: 'civ-4', type: 'neutral', trust: 50, tradeVolume: 300, conflicts: 3, treaties: [], lastInteraction: Date.now() - 259200000 },
    { sourceId: 'civ-4', targetId: 'civ-5', type: 'friendly', trust: 65, tradeVolume: 2100, conflicts: 0, treaties: [], lastInteraction: Date.now() - 86400000 },
    { sourceId: 'civ-5', targetId: 'civ-6', type: 'neutral', trust: 30, tradeVolume: 100, conflicts: 0, treaties: [], lastInteraction: Date.now() - 604800000 },
  ];

  const alliances: Alliance[] = [
    {
      id: 'alliance-1',
      name: '银河防御协定',
      leaderId: 'civ-1',
      members: [
        { civilizationId: 'civ-1', joinedAt: Date.now() - 2592000000, role: 'leader', contribution: 5000 },
        { civilizationId: 'civ-5', joinedAt: Date.now() - 1728000000, role: 'member', contribution: 3200 },
      ],
      foundedAt: Date.now() - 2592000000,
      description: '维护银河系和平与贸易自由',
      color: