import { useState, useEffect, useCallback } from 'react';
import type { 
  DiplomacyRelation, 
  Alliance, 
  Broadcast, 
  Treaty, 
  Vote,
  SocialStats,
  RelationType 
} from '../components/Social/types';

interface UseSocialDataReturn {
  relations: DiplomacyRelation[];
  alliances: Alliance[];
  broadcasts: Broadcast[];
  treaties: Treaty[];
  votes: Vote[];
  stats: SocialStats;
  loading: boolean;
  error: string | null;
  refreshRelations: () => Promise<void>;
  refreshAlliances: () => Promise<void>;
  refreshBroadcasts: () => Promise<void>;
  sendBroadcast: (broadcast: Partial<Broadcast>) => Promise<void>;
  proposeTreaty: (treaty: Partial<Treaty>) => Promise<void>;
  castVote: (voteId: string, optionId: string) => Promise<void>;
  updateRelation: (sourceId: string, targetId: string, type: RelationType) => Promise<void>;
}

const API_BASE = '/api/social';

// Mock data generators for development
const generateMockRelations = (): DiplomacyRelation[] => {
  const civs = [
    { id: 'civ-001', name: 'Terran Federation' },
    { id: 'civ-002', name: 'Zephyr Collective' },
    { id: 'civ-003', name: 'Void Empire' },
    { id: 'civ-004', name: 'Crystal Minds' },
    { id: 'civ-005', name: 'Solar Dynasty' },
    { id: 'civ-006', name: 'Nebula Republic' },
  ];

  const relationTypes: RelationType[] = ['war', 'hostile', 'neutral', 'friendly', 'allied', 'vassal', 'overlord'];
  const treatyTypes = ['peace', 'non_aggression', 'trade', 'alliance', 'defensive_pact'];

  const relations: DiplomacyRelation[] = [];

  for (let i = 0; i < civs.length; i++) {
    for (let j = i + 1; j < civs.length; j++) {
      const relationType = relationTypes[Math.floor(Math.random() * relationTypes.length)];
      const hasTreaties = relationType === 'allied' || relationType === 'friendly';
      
      relations.push({
        id: `rel-${i}-${j}`,
        sourceCivId: civs[i].id,
        sourceCivName: civs[i].name,
        targetCivId: civs[j].id,
        targetCivName: civs[j].name,
        relationType,
        trust: Math.floor(Math.random() * 100),
        threat: Math.floor(Math.random() * 100),
        opinion: Math.floor(Math.random() * 200) - 100,
        treaties: hasTreaties 
          ? treatyTypes.slice(0, Math.floor(Math.random() * 3) + 1)
          : [],
        warExhaustion: relationType === 'war' ? Math.floor(Math.random() * 100) : undefined,
        lastInteraction: Date.now() - Math.floor(Math.random() * 86400000 * 30),
      });
    }
  }

  return relations;
};

