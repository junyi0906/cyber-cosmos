"""
Decision Types Module - Defines decision type enums and related structures
for the Agent Decision Engine Enhancement (feat-012)
"""

from enum import Enum, auto
from dataclasses import dataclass, field
from typing import Dict, List, Optional, Any
import time


class DecisionType(Enum):
    """Enumeration of all possible decision types an agent can make"""
    
    # Diplomatic Decisions
    DECLARE_WAR = auto()
    SEEK_PEACE = auto()
    FORM_ALLIANCE = auto()
    BREAK_ALLIANCE = auto()
    SIGN_TREATY = auto()
    BREAK_TREATY = auto()
    SEND_AMBASSADOR = auto()
    RECALL_AMBASSADOR = auto()
    
    # Economic Decisions
    INITIATE_TRADE = auto()
    EMBARGO = auto()
    SHARE_RESOURCES = auto()
    REQUEST_AID = auto()
    DENY_TRADE = auto()
    
    # Military Decisions
    ATTACK = auto()
    DEFEND = auto()
    RETREAT = auto()
    PATROL = auto()
    OCCUPY = auto()
    LIBERATE = auto()
    
    # Technology Decisions
    RESEARCH_TECH = auto()
    SHARE_TECH = auto()
    STEAL_TECH = auto()
    SABOTAGE_RESEARCH = auto()
    
    # Communication Decisions
    BROADCAST_MESSAGE = auto()
    SEND_PRIVATE_COMM = auto()
    ISSUE_WARNING = auto()
    SEND_THREAT = auto()
    
    # Expansion Decisions
    COLONIZE = auto()
    ABANDON_COLONY = auto()
    TERRAFORM = auto()
    EXPLORE = auto()
    
    # Internal Decisions
    CHANGE_GOVERNMENT = auto()
    IMPLEMENT_POLICY = auto()
    SUPPRESS_REBELLION = auto()
    CELEBRATE = auto()
    
    # Neutral/Passive
    WAIT = auto()
    OBSERVE = auto()
    DO_NOTHING = auto()


class DecisionPriority(Enum):
    """Priority levels for decisions"""
    CRITICAL = 5    # Immediate action required (survival threats)
    HIGH = 4        # Urgent but not immediate (war, major events)
    MEDIUM = 3      # Normal priority (diplomacy, trade)
    LOW = 2         # Can be delayed (exploration, minor policies)
    TRIVIAL = 1     # Background activities


class DecisionFactor(Enum):
    """Factors that influence decision making"""
    # Diplomatic Factors
    DIPLOMATIC_RELATION = "diplomatic_relation"
    TREATY_STATUS = "treaty_status"
    TRUST_LEVEL = "trust_level"
    
    # Alliance Factors
    ALLIANCE_MEMBERSHIP = "alliance_membership"
    ALLIANCE_OBLIGATIONS = "alliance_obligations"
    ALLIANCE_VOTING = "alliance_voting"
    
    # Event Factors
    RECENT_EVENTS = "recent_events"
    THREAT_LEVEL = "threat_level"
    OPPORTUNITY_SCORE = "opportunity_score"
    
    # Resource Factors
    RESOURCE_AVAILABILITY = "resource_availability"
    ECONOMIC_HEALTH = "economic_health"
    MILITARY_STRENGTH = "military_strength"
    
    # Social Factors
    POPULATION_MORALE = "population_morale"
    CULTURAL_IDENTITY = "cultural_identity"
    INTERNAL_STABILITY = "internal_stability"
    
    # Strategic Factors
    LONG_TERM_GOALS = "long_term_goals"
    TERRITORIAL_AMBITION = "territorial_ambition"
    TECHNOLOGICAL_PROGRESS = "technological_progress"


@dataclass
class DiplomaticContext:
    """Context about diplomatic relations with other civilizations"""
    relation_type: str = "neutral"  # friendly, neutral, hostile, unknown
    trust_score: float = 0.5  # 0.0 to 1.0
    treaty_ids: List[str] = field(default_factory=list)
    recent_interactions: List[Dict[str, Any]] = field(default_factory=list)
    grievances: List[Dict[str, Any]] = field(default_factory=list)
    favors_owed: int = 0
    last_contact_turn: int = 0


@dataclass
class AllianceContext:
    """Context about alliance membership and obligations"""
    is_member: bool = False
    alliance_id: Optional[str] = None
    alliance_name: Optional[str] = None
    member_ids: List[str] = field(default_factory=list)
    obligations: List[str] = field(default_factory=list)  # defense, trade, etc.
    voting_power: float = 1.0
    contribution_history: List[Dict[str, Any]] = field(default_factory=list)
    pending_votes: List[Dict[str, Any]] = field(default_factory=list)


@dataclass
class EventImpact:
    """Impact of a recent event on decision making"""
    event_id: str
    event_type: str
    severity: float  # 0.0 to 1.0
    affected_entities: List[str]
    impact_type: str  # positive, negative, neutral
    timestamp: float
    decay_rate: float = 0.1  # How quickly impact fades
    description: str = ""


@dataclass
class DecisionOption:
    """A possible decision option with calculated weights"""
    decision_type: DecisionType
    base_weight: float
    modified_weight: float
    factors: Dict[DecisionFactor, float] = field(default_factory=dict)
    target_id: Optional[str] = None
    parameters: Dict[str, Any] = field(default_factory=dict)
    reasoning: List[str] = field(default_factory=list)


@dataclass
class DecisionResult:
    """Final decision result with explanation"""
    chosen_option: DecisionOption
    all_options: List[DecisionOption]
    confidence: float
    explanation: str
    reasoning_chain: List[str]
    timestamp: float = field(default_factory=time.time)
    agent_id: Optional[str] = None
    context_snapshot: Optional[Dict[str, Any]] = None