@dataclass
class DecisionContext:
    """
    Encapsulates the decision context for an agent.
    Contains diplomacy relations, alliance status, and event impacts.
    """
    civilization_id: str
    civilization_name: str
    
    # Civilization attributes
    military_power: float = 0.5
    economic_power: float = 0.5
    technology_level: float = 0.5
    cultural_influence: float = 0.5
    population: int = 1000
    
    # Diplomatic context
    diplomacy_relations: Dict[str, DiplomaticRelation] = field(default_factory=dict)
    
    # Alliance context
    current_alliance: Optional[AllianceInfo] = None
    pending_alliance_invites: List[AllianceInfo] = field(default_factory=list)
    
    # Event context
    recent_events: List[EventImpact] = field(default_factory=list)
    
    # Strategic context
    current_threats: List[str] = field(default_factory=list)
    available_resources: float = 100.0
    expansion_opportunities: List[str] = field(default_factory=list)
    
    # Ideology and personality
    ideology: str = "neutral"
    aggression_tendency: float = 0.5
    cooperation_tendency: float = 0.5
    risk_tolerance: float = 0.5
    
    # Timestamp
    context_time: float = field(default_factory=lambda: time.time())
    
    def get_relation_with(self, civ_id: str) -> Optional[DiplomaticRelation]:
        """Get diplomatic relation with a specific civilization"""
        return self.diplomacy_relations.get(civ_id)
    
    def get_trust_level(self, civ_id: str) -> float:
        """Get trust level with a specific civilization"""
        relation = self.get_relation_with(civ_id)
        return relation.trust_level if relation else 0.5
    
    def get_threat_level(self, civ_id: str) -> float:
        """Get threat assessment for a specific civilization"""
        relation = self.get_relation_with(civ_id)
        return relation.threat_assessment if relation else 0.5
    
    def is_allied_with(self, civ_id: str) -> bool:
        """Check if allied with a specific civilization"""
        if self.current_alliance:
            return civ_id in self.current_alliance.member_ids
        return False
    
    def is_at_war_with(self, civ_id: str) -> bool:
        """Check if at war with a specific civilization"""
        relation = self.get_relation_with(civ_id)
        return relation.status == DiplomacyStatus.AT_WAR if relation else False
    
    def get_recent_event_impact(self, event_type: str) -> float:
        """Calculate cumulative impact of recent events of a specific type"""
        total_impact = 0.0
        current_time = time.time()
        for event in self.recent_events:
            if event.event_type == event_type:
                # Decay impact based on time (events older than 1000 time units have minimal impact)
                time_factor = max(0.1, 1.0 - (current_time - event.timestamp) / 1000.0)
                total_impact += event.severity * time_factor
        return min(1.0, total_impact)
    
    def to_dict(self) -> Dict[str, Any]:
        return {
            'civilization_id': self.civilization_id,
            'civilization_name': self.civilization_name,
            'military_power': self.military_power,
            'economic_power': self.economic_power,
            'technology_level': self.technology_level,
            'cultural_influence': self.cultural_influence,
            'population': self.population,
            'diplomacy_relations': {k: v.to_dict() for k, v in self.diplomacy_relations.items()},
            'current_alliance': self.current_alliance.to_dict() if self.current_alliance else None,
            'pending_alliance_invites': [a.to_dict() for a in self.pending_alliance_invites],
            'recent_events': [e.to_dict() for e in self.recent_events],
            'current_threats': self.current_threats,
            'available_resources': self.available_resources,
            'expansion_opportunities': self.expansion_opportunities,
            'ideology': self.ideology,
            'aggression_tendency': self.aggression_tendency,
            'cooperation_tendency': self.cooperation_tendency,
            'risk_tolerance': self.risk_tolerance,
            'context_time': self.context_time
        }


