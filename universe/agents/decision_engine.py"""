class DecisionContext:
    """
    Encapsulates all context needed for decision making including
    diplomatic relations, alliance status, and event impacts.
    """
    
    def __init__(
        self,
        agent_id: str,
        current_turn: int = 0,
        resources: Optional[Dict[str, float]] = None,
        military_strength: float = 0.5,
        population_morale: float = 0.5,
        economic_health: float = 0.5,
        technological_level: float = 0.5
    ):
        self.agent_id = agent_id
        self.current_turn = current_turn
        self.timestamp = time.time()
        
        # Core state
        self.resources = resources or {}
        self.military_strength = military_strength
        self.population_morale = population_morale
        self.economic_health = economic_health
        self.technological_level = technological_level
        
        # Diplomatic contexts keyed by target agent/civilization ID
        self.diplomatic_contexts: Dict[str, DiplomaticContext] = {}
        
        # Alliance context (single alliance membership)
        self.alliance_context: Optional[AllianceContext] = None
        
        # Recent events and their impacts
        self.event_impacts: List[EventImpact] = []
        
        # Active threats and opportunities
        self.active_threats: List[Dict[str, Any]] = []
        self.active_opportunities: List[Dict[str, Any]] = []
        
        # Long-term goals and priorities
        self.strategic_goals: List[str] = []
        self.priority_modifier: Dict[DecisionType, float] = {}
        
        # Memory of recent decisions
        self.recent_decisions: List[DecisionResult] = []
        
    def add_diplomatic_context(
        self,
        target_id: str,
        relation_type: str = "neutral",
        trust_score: float = 0.5,
        treaty_ids: Optional[List[str]] = None,
        recent_interactions: Optional[List[Dict[str, Any]]] = None,
        grievances: Optional[List[Dict[str, Any]]] = None,
        favors_owed: int = 0,
        last_contact_turn: int = 0
    ) -> None:
        """Add or update diplomatic context for a target civilization"""
        self.diplomatic_contexts[target_id] = DiplomaticContext(
            relation_type=relation_type,
            trust_score=trust_score,
            treaty_ids=treaty_ids or [],
            recent_interactions=recent_interactions or [],
            grievances=grievances or [],
            favors_owed=favors_owed,
            last_contact_turn=last_contact_turn
        )
    
    def set_alliance_context(
        self,
        is_member: bool = False,
        alliance_id: Optional[str] = None,
        alliance_name: Optional[str] = None,
        member_ids: Optional[List[str]] = None,
        obligations: Optional[List[str]] = None,
        voting_power: float = 1.0,
        contribution_history: Optional[List[Dict[str, Any]]] = None,
        pending_votes: Optional[List[Dict[str, Any]]] = None
    ) -> None:
        """Set the alliance context for this agent"""
        self.alliance_context = AllianceContext(
            is_member=is_member,
            alliance_id=alliance_id,
            alliance_name=alliance_name,
            member_ids=member_ids or [],
            obligations=obligations or [],
            voting_power=voting_power,
            contribution_history=contribution_history or [],
            pending_votes=pending_votes or []
        )
    
    def add_event_impact(
        self,
        event_id: str,
        event_type: str,
        severity: float,
        affected_entities: List[str],
        impact_type: str,
        description: str = "",
        decay_rate: float = 0.1
    ) -> None:
        """Add an event impact to the context"""
        self.event_impacts.append(EventImpact(
            event_id=event_id,
            event_type=event_type,
            severity=severity,
            affected_entities=affected_entities,
            impact_type=impact_type,
            timestamp=time.time(),
            decay_rate=decay_rate,
            description=description
        ))
    
    def add_threat(
        self,
        threat_id: str,
        threat_type: str,
        severity: float,
        source_id: Optional[str] = None,
        deadline_turn: Optional[int] = None
    ) -> None:
        """Add an active threat"""
        self.active_threats.append({
            "threat_id": threat_id,
            "threat_type": threat_type,
            "severity": severity,
            "source_id": source_id,
            "deadline_turn": deadline_turn,
            "detected_turn": self.current_turn
        })
    
    def add_opportunity(
        self,
        opportunity_id: str,
        opportunity_type: str,
        potential_value: float,
        expires_turn: Optional[int] = None
    ) -> None:
        """Add an active opportunity"""
        self.active_opportunities.append({
            "opportunity_id": opportunity_id,
            "opportunity_type": opportunity_type,
            "potential_value": potential_value,
            "expires_turn": expires_turn,
            "detected_turn": self.current_turn
        })
    
    def get_effective_trust(self, target_id: str) -> float:
        """Get effective trust score considering recent events"""
        base_trust = 0.5
        if target_id in self.diplomatic_contexts:
            base_trust = self.diplomatic_contexts[target_id].trust_score
        
        # Modify based on recent events involving this target
        event_modifier = 0.0
        for impact in self.event_impacts:
            if target_id in impact.affected_entities:
                decayed_severity = self._decay_impact(impact)
                if impact.impact_type == "positive":
                    event_modifier += decayed_severity * 0.1
                elif impact.impact_type == "negative":
                    event_modifier -= decayed_severity * 0.1
        
        return max(0.0, min(1.0, base_trust + event_modifier))
    
    def _decay_impact(self, impact: EventImpact) -> float:
        """Calculate decayed impact severity based on time"""
        time_elapsed = time.time() - impact.timestamp
        decay_factor = math.exp(-impact.decay_rate * time_elapsed / 3600)  # Decay per hour
        return impact.severity * decay_factor
    
    def to_dict(self) -> Dict[str, Any]:
        """Serialize context to dictionary"""
        return {
            "agent_id": self.agent_id,
            "current_turn": self.current_turn,
            "timestamp": self.timestamp,
            "resources": self.resources,
            "military_strength": self.military_strength,
            "population_morale": self.population_morale,
            "economic_health": self.economic_health,
            "technological_level": self.technological_level,
            "diplomatic_contexts": {
                k: {
                    "relation_type": v.relation_type,
                    "trust_score": v.trust_score,
                    "treaty_ids": v.treaty_ids,
                    "favors_owed": v.favors_owed
                }
                for k, v in self.diplomatic_contexts.items()
            },
            "alliance_context": {
                "is_member": self.alliance_context.is_member if self.alliance_context else False,
                "alliance_id": self.alliance_context.alliance_id if self.alliance_context else None,
                "member_count": len(self.alliance_context.member_ids) if self.alliance_context else 0
            },
            "active_threats_count": len(self.active_threats),
            "active_opportunities_count": len(self.active_opportunities),
            "recent_events_count": len(self.event_impacts)
        }


