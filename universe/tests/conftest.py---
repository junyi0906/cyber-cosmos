@pytest.fixture
def mock_universe_state(sample_universe_state):
    """Mock universe state manager."""
    from unittest.mock import MagicMock
    state = MagicMock()
    state.get_state.return_value = sample_universe_state
    state.get_civilization.return_value = sample_universe_state["civilizations"]["civ_001"]
    state.get_all_civilizations.return_value = sample_universe_state["civilizations"]
    state.update_civilization.return_value = True
    state.add_event.return_value = True
    return state


@pytest.fixture
