#!/bin/bash

# Cyber-Cosmos Trade System Performance Test Runner
# This script runs all performance tests and generates reports

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPORTS_DIR="${SCRIPT_DIR}/reports"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Create reports directory
mkdir -p "${REPORTS_DIR}"

# Check if Artillery is installed
if ! command -v artillery &> /dev/null; then
    log_error "Artillery is not installed. Please run: npm install -g artillery"
    exit 1
fi

# Check if server is running
check_server() {
    log_info "Checking if server is running..."
    if curl -s http://localhost:3000/health > /dev/null 2>&1; then
        log_info "Server is running"
        return 0
    else
        log_warn "Server is not running. Attempting to start..."
        return 1
    fi
}

# Run main load test
run_load_test() {
    log_info "Running main trade load test..."
    
    artillery run \
        --output "${REPORTS_DIR}/load-test-${TIMESTAMP}.json" \
        --overrides '{"config": {"environments": {"production": {"target": "http://localhost:3000"}}}}' \
        "${SCRIPT_DIR}/trade-load.yml" 2>&1 | tee "${REPORTS_DIR}/load-test-${TIMESTAMP}.log"
    
    log_info "Load test completed"
}

# Run cache breakthrough test
run_cache_test() {
    log_info "Running cache breakthrough test..."
    
    artillery run \
        --output "${REPORTS_DIR}/cache-test-${TIMESTAMP}.json" \
        "${SCRIPT_DIR}/cache-breakthrough-test.yml" 2>&1 | tee "${REPORTS_DIR}/cache-test-${TIMESTAMP}.log"
    
    log_info "Cache test completed"
}

# Run deadlock test
run_deadlock_test() {
    log_info "Running deadlock detection test..."
    
    artillery run \
        --output "${REPORTS_DIR}/deadlock-test-${TIMESTAMP}.json" \
        "${SCRIPT_DIR}/deadlock-test.yml" 2>&1 | tee "${REPORTS_DIR}/deadlock-test-${TIMESTAMP}.log"
    
    log_info "Deadlock test completed"
}

# Generate HTML report
generate_report() {
    log_info "Generating performance report..."
    
    local report_file="${REPORTS_DIR}/performance-report-${TIMESTAMP}.html"
    
    # Combine all test results
    node "${SCRIPT_DIR}/generate-report.js" \
        --load "${REPORTS_DIR}/load-test-${TIMESTAMP}.json" \
        --cache "${REPORTS_DIR}/cache-test-${TIMESTAMP}.json" \
        --deadlock "${REPORTS_DIR}/deadlock-test-${TIMESTAMP}.json" \
        --output "${report_file}"
    
    log_info "Report generated: ${report_file}"
}

# Main execution
main() {
    log_info "Starting Cyber-Cosmos Performance Test Suite"
    log_info "Timestamp: ${TIMESTAMP}"
    
    check_server || {
        log_error "Server is not available. Please start the server first."
        exit 1
    }
    
    # Run tests sequentially
    run_load_test
    run_cache_test
    run_deadlock_test
    
    # Generate combined report
    generate_report
    
    log_info "All tests completed successfully!"
    log_info "Reports available at: ${REPORTS_DIR}"
}

# Run main function
main "$@"
