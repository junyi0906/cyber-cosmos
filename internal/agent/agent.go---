package agent

import (
	"context"
	"sync"
)

// Agent represents a civilization agent in the universe
type Agent struct {
	ID           string
	Name         string
	Type         AgentType
	Status       AgentStatus
	Capabilities []string
	mu           sync.RWMutex
}

// AgentType defines the type of agent
type AgentType string

const (
	AgentTypeCivilization AgentType = "civilization"
	AgentTypeTrader       AgentType = "trader"
	AgentTypeExplorer     AgentType = "explorer"
)

// AgentStatus defines the current status of an agent
type AgentStatus string

const (
	StatusActive   AgentStatus = "active"
	StatusIdle     AgentStatus = "idle"
	StatusDormant  AgentStatus = "dormant"
	StatusDestroyed AgentStatus = "destroyed"
)

// NewAgent creates a new agent instance
func NewAgent(id, name string, agentType AgentType) *Agent {
	return &Agent{
		ID:           id,
		Name:         name,
		Type:         agentType,
		Status:       StatusActive,
		Capabilities: make([]string, 0),
	}
}

// Execute performs an action based on the agent's decision
func (a *Agent) Execute(ctx context.Context, action string) error {
	a.mu.Lock()
	defer a.mu.Unlock()

	// TODO: Implement action execution logic
	return nil
}

// UpdateStatus changes the agent's current status
func (a *Agent) UpdateStatus(status AgentStatus) {
	a.mu.Lock()
	defer a.mu.Unlock()
	a.Status = status
}

// GetStatus returns the current status of the agent
func (a *Agent) GetStatus() AgentStatus {
	a.mu.RLock()
	defer a.mu.RUnlock()
	return a.Status
}