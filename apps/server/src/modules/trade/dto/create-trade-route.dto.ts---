import { IsString, IsEnum, IsInt, Min, IsNotEmpty } from 'class-validator';
import { ResourceType } from '../entities/trade-route.entity';

export class CreateTradeRouteDto {
  @IsString()
  @IsNotEmpty()
  fromCivilizationId: string;

  @IsString()
  @IsNotEmpty()
  toCivilizationId: string;

  @IsEnum(ResourceType)
  resourceType: ResourceType;

  @IsInt()
  @Min(1)
  quantity: number;
}