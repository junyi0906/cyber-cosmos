import { IsString, IsEnum, IsNumber, IsUUID, Min, Max } from 'class-validator';
import { ResourceType } from '../interfaces/trade.interface';

export class CreateTradeRouteDto {
  @IsUUID()
  @IsString()
  fromCivId: string;

  @IsUUID()
  @IsString()
  toCivId: string;

  @IsEnum(ResourceType)
  resourceType: ResourceType;

  @IsNumber()
  @Min(1)
  @Max(10000)
  amount: number;
}