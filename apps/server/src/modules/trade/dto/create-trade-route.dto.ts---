import { IsString, IsEnum, IsInt, IsPositive, IsUUID, Min } from 'class-validator';
import { ResourceType } from '../entities/trade-route.entity';

export class CreateTradeRouteDto {
  @IsUUID()
  @IsString()
  sourceCivilizationId: string;

  @IsUUID()
  @IsString()
  targetCivilizationId: string;

  @IsEnum(ResourceType)
  resourceType: ResourceType;

  @IsInt()
  @IsPositive()
  quantity: number;

  @IsInt()
  @Min(1)
  maxCycles?: number;
}