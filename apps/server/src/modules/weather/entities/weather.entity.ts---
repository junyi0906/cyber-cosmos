import { Entity, PrimaryGeneratedColumn, Column, CreateDateColumn } from 'typeorm';

@Entity('weather_history')
export class Weather {
  @PrimaryGeneratedColumn()
  id: number;

  @Column()
  cycle: number;

  @Column()
  type: string;

  @Column()
  name: string;

  @Column({ type: 'text' })
  description: string;

  @Column({ type: 'text', nullable: true })
  effects: string;

  @Column({ default: 1 })
  duration: number;

  @CreateDateColumn()
  createdAt: Date;
}