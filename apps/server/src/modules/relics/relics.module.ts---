import { Module } from '@nestjs/common';
import { TypeOrmModule } from '@nestjs/typeorm';
import { Relic } from './relic.entity';
import { RelicService } from './relic.service';
import { RelicGenerator } from './relic.generator';
import { RelicSpawnListener } from './spawn.listener';

@Module({
  imports: [TypeOrmModule.forFeature([Relic])],
  providers: [RelicService, RelicGenerator, RelicSpawnListener],
  exports: [RelicService, RelicSpawnListener],
})
export class RelicsModule {}