import { Injectable, Logger, NotFoundException } from '@nestjs/common';
import { InjectRepository } from '@nestjs/typeorm';
import { Repository, DataSource } from 'typeorm';
import { Relic, RelicStatus } from '../../entities/relic.entity';
import { EventEmitter2 } from '@nestjs/event-emitter';

export interface ContestResult {
  success: boolean;
  attackerId: string;
  attackerLosses: number;
  defenderLosses: number;
  relic: Relic;
}

@Injectable()
export class RelicService {
  private readonly logger = new Logger(RelicService.name);

  constructor(
    @InjectRepository(Relic)
    private readonly relicRepository: Repository<Relic>,
    private readonly eventEmitter: EventEmitter2,
    private readonly dataSource: DataSource,
  ) {}

  async findAll(): Promise<Relic[]> {
    return await this.relicRepository.find({
      order: { createdAt: 'DESC' },
    });
  }

  async findOne(id: string): Promise<Relic> {
    const relic = await this.relicRepository.findOne({ where: { id } });
    if (!relic) {
      throw new NotFoundException(`Relic with ID ${id} not found`);
    }
    return relic;
  }

  /**
   * 占领遗迹
   */
  async claimRelic(relicId: string, ownerId: string, ownerName: string): Promise<Relic> {
    const relic = await this.findOne(relicId);

    if (relic.status === RelicStatus.DESTROYED) {
      throw new Error('Cannot claim a destroyed relic');
    }

    if (relic.status === RelicStatus.CLAIMED && relic.ownerId === ownerId) {
      throw new Error('You already own this relic');
    }

    relic.ownerId = ownerId;
    relic.ownerName = ownerName;
    relic.status = RelicStatus.CLAIMED;

    const savedRelic = await this.relicRepository.save(relic);

    this.eventEmitter.emit('relic.claimed', {
      relic: savedRelic,
      ownerId,
      timestamp: new Date(),
    });

    return savedRelic;
  }

  /**
   * 发起遗迹争夺战
   */
  async contestRelic(
    relicId: string,
    attackerId: string,
    attackerName: string,
    attackerPower: number,
  ): Promise<ContestResult> {
    const relic = await this.findOne(relicId);

    if (relic.status === RelicStatus.DESTROYED) {
      throw new Error('Cannot contest a destroyed relic');
    }

    if (relic.ownerId === attackerId) {
      throw new Error('Cannot contest your own relic');
    }

    // 计算战斗结果
    const defensePower = relic.defensePower;
    const attackEfficiency = Math.random() * 0.4 + 0.8; // 0.8 - 1.2
    const defenseEfficiency = Math.random() * 0.4 + 0.8;

    const effectiveAttack = attackerPower * attackEfficiency;
    const effectiveDefense = defensePower * defenseEfficiency;

    const success = effectiveAttack > effectiveDefense;

    // 计算损失
    const attackerLosses = Math.floor(defensePower * 0.3 * (success ? 0.5 : 1));
    const defenderLosses = Math.floor(attackerPower * 0.2 * (success ? 1 : 0.5));

    if (success) {
      // 攻击方胜利，转移所有权
      relic.ownerId = attackerId;
      relic.ownerName = attackerName;
      relic.status = RelicStatus.CLAIMED;
      relic.defensePower = Math.max(50, Math.floor(defensePower * 0.7)); // 防御力受损

      await this.relicRepository.save(relic);

      this.eventEmitter.emit('relic.contested', {
        relic,
        winnerId: attackerId,
        loserId: relic.ownerId,
        timestamp: new Date(),
      });
    } else {
      // �