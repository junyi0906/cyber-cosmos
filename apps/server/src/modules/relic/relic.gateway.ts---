import { WebSocketGateway, WebSocketServer } from '@nestjs/websockets';
import { Server } from 'socket.io';

@WebSocketGateway({
  cors: {
    origin: '*',
  },
})
export class RelicGateway {
  @WebSocketServer()
  server: Server;

  broadcastEcho(payload: any) {
    this.server.emit('event:relic_echo', payload);
  }
}