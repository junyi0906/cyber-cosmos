INSERT INTO weather_history (time, weather_type, intensity, affected_sectors)
VALUES 
    (NOW() - INTERVAL '1 hour', 'calm', 1.0, '[]'::jsonb),
    (NOW(), 'calm', 1.0, '[]'::jsonb);

-- ============================================
-- 7. 视图：活跃贸易路线视图
-- ============================================
CREATE OR REPLACE VIEW v_active_trade_routes AS
SELECT 
    tr.id,
    tr.source_civ_id,
    c1.name as source_civ_name,
    tr.target_civ_id,
    c2.name as target_civ_name,
    tr.resource_type,
    tr.rate_per_tick,
    tr.status,
    tr.created_at
FROM trade_routes tr
LEFT JOIN civilizations c1 ON tr.source_civ_id = c1.id
LEFT JOIN civilizations c2 ON tr.target_civ_id = c2.id
WHERE tr.status = 'active';

COMMENT ON VIEW v_active_trade_routes IS '活跃贸易路线视图';

-- ============================================
-- 8. 视图：市场深度视图
-- ============================================
CREATE OR REPLACE VIEW v_market_depth AS
SELECT 
    resource,
    type,
    price,
    SUM(quantity - filled_quantity) as available_quantity,
    COUNT(*) as order_count
FROM market_orders
WHERE status IN ('open', 'partial')
GROUP BY resource, type, price
ORDER BY resource, type, price;

COMMENT ON VIEW v_market_depth IS '市场深度视图（按资源类型聚合）';

-- ============================================
-- 9. 函数：计算全局供需指数
-- ============================================
CREATE OR REPLACE FUNCTION calculate_supply_demand_index(p_resource VARCHAR)
RETURNS TABLE (
    resource VARCHAR,
    buy_volume DECIMAL,
    sell_volume DECIMAL,
    supply_demand_ratio DECIMAL,
    avg_buy_price DECIMAL,
    avg_sell_price DECIMAL
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        p_resource::VARCHAR,
        COALESCE(SUM(CASE WHEN mo.type = 'buy' THEN mo.quantity - mo.filled_quantity ELSE 0 END), 0)::DECIMAL as buy_volume,
        COALESCE(SUM(CASE WHEN mo.type = 'sell' THEN mo.quantity - mo.filled_quantity ELSE 0 END), 0)::DECIMAL as sell_volume,
        CASE 
            WHEN COALESCE(SUM(CASE WHEN mo.type = 'sell' THEN mo.quantity - mo.filled_quantity ELSE 0 END), 0) = 0 
            THEN 999.99
            ELSE 
                COALESCE(SUM(CASE WHEN mo.type = 'buy' THEN mo.quantity - mo.filled_quantity ELSE 0 END), 0)::DECIMAL / 
                COALESCE(SUM(CASE WHEN mo.type = 'sell' THEN mo.quantity - mo.filled_quantity ELSE 0 END), 0)::DECIMAL
        END as supply_demand_ratio,
        COALESCE(AVG(CASE WHEN mo.type = 'buy' THEN mo.price END), 0)::DECIMAL as avg_buy_price,
        COALESCE(AVG(CASE WHEN mo.type = 'sell' THEN mo.price END), 0)::DECIMAL as avg_sell_price
    FROM market_orders mo
    WHERE mo.resource = p_resource
      AND mo.status IN ('open', 'partial');
END;
$$ LANGUAGE plpgsql;

COMMENT ON FUNCTION calculate_supply_demand_index IS '计算指定资源的供需指数';

