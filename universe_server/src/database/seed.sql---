-- ============================================
-- Insert Initial Universe Events
-- ============================================

INSERT INTO universe_events (event_type, description, impact_data, tick, timestamp) VALUES (
    'civilization_birth',
    'The universe awakens as three great civilizations emerge from the cosmic void, each with their own vision for the future.',
    '{
        "significance": "major",
        "affected_civilizations": ["Aethon Collective", "Vorthan Dominion", "Sylphid Harmony"],
        "narrative_weight": 10
    }'::jsonb,
    0,
    CURRENT_TIMESTAMP
);

-- ============================================
-- Insert Initial Diplomacy State
-- ============================================

-- Create initial diplomatic awareness between civilizations
INSERT INTO diplomacy_logs (from_civ_id, to_civ_id, action_type, result, timestamp, details)
SELECT 
    c1.id,
    c2.id,
    'first_contact',
    'accepted',
    CURRENT_TIMESTAMP,
    '{"description": "Initial detection and establishment of communication protocols"}'::jsonb
FROM civilizations c1
CROSS JOIN civilizations c2
WHERE c1.name = 'Aethon Collective' AND c2.name = 'Vorthan Dominion';

INSERT INTO diplomacy_logs (from_civ_id, to_civ_id, action_type, result, timestamp, details)
SELECT 
    c1.id,
    c2.id,
    'first_contact',
    'accepted',
    CURRENT_TIMESTAMP,
    '{"description": "Peaceful exchange of cultural information"}'::jsonb
FROM civilizations c1
CROSS JOIN civilizations c2
WHERE c1.name = 'Aethon Collective' AND c2.name = 'Sylphid Harmony';

INSERT INTO diplomacy_logs (from_civ_id, to_civ_id, action_type, result, timestamp, details)
SELECT 
    c1.id,
    c2.id,
    'first_contact',
    'pending',
    CURRENT_TIMESTAMP,
    '{"description": "Tense initial contact, monitoring situation"}'::jsonb
FROM civilizations c1
CROSS JOIN civilizations c2
WHERE c1.name = 'Vorthan Dominion' AND c2.name = 'Sylphid Harmony';