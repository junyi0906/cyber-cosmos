-- ============================================
-- Insert Initial Diplomacy State
-- ============================================

-- First contact between Aethor and Sylphid (friendly)
INSERT INTO diplomacy_logs (from_civ_id, to_civ_id, action_type, result, timestamp, details)
SELECT 
    c1.id,
    c2.id,
    'first_contact',
    'accepted',
    NOW(),
    '{
        "initiator_message": "Greetings, fellow seekers of knowledge. We come in peace.",
        "response_message": "Welcome, travelers. The Harmony embraces new friends.",
        "relation_change": 15
    }'::jsonb
FROM civilizations c1, civilizations c2
WHERE c1.name = 'Aethor Collective' AND c2.name = 'Sylphid Harmony'
ON CONFLICT DO NOTHING;

-- First contact between Vorthan and Aethor (tense)
INSERT INTO diplomacy_logs (from_civ_id, to_civ_id, action_type, result, timestamp, details)
SELECT 
    c1.id,
    c2.id,
    'first_contact',
    'accepted',
    NOW(),
    '{
        "initiator_message": "We are the Vorthan. Your territory is now of interest to us.",
        "response_message": "We acknowledge your presence. Let us discuss peaceful coexistence.",
        "relation_change": -5
    }'::jsonb
FROM civilizations c1, civilizations c2
WHERE c1.name = 'Vorthan Empire' AND c2.name = 'Aethor Collective'
ON CONFLICT DO NOTHING;

