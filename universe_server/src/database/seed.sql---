-- ============================================
-- Insert Initial Mother Civilizations
-- ============================================

-- Civilization 1: The Aethor Collective
-- A highly advanced, peaceful civilization focused on knowledge and exploration
INSERT INTO civilizations (id, name, attributes, tech_level, status, created_at) VALUES (
    uuid_generate_v4(),
    'Aethor Collective',
    '{
        "ideology": "knowledge_seeking",
        "population": 85000000000,
        "military_power": 35,
        "economic_power": 85,
        "technology_focus": "quantum_computing",
        "home_system": "Aethor Prime",
        "government_type": "technocratic_council",
        "primary_values": ["knowledge", "exploration", "cooperation"],
        "trust_base": 0.7,
        "threat_tolerance": 0.3,
        "expansion_drive": 0.5,
        "color": "#4A90D9",
        "symbol": "crystal_star"
    }'::jsonb,
    42,
    'active',
    NOW()
) ON CONFLICT DO NOTHING;

-- Civilization 2: The Vorthan Empire
-- A militaristic, expansionist civilization with strong industrial base
