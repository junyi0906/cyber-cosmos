    '{
        "event_category": "meta",
        "severity": "info",
        "affected_systems": ["Aethor Prime", "Vorthan Major", "Sylphid Garden"]
    }'::jsonb,
    0,
    NOW()
) ON CONFLICT DO NOTHING;

