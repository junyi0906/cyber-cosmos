    'Aethon Collective',
    '{
        "military": 7,
        "economy": 6,
        "technology": 8,
        "culture": 5,
        "population": 8500000000,
        "home_planet": "Aethon Prime",
        "ideology": "technocratic_collectivism",
        "traits": ["curious", "expansionist", "scientific"],
        "color": "#4A90D9",
        "coordinates": {"x": 120, "y": 85, "z": -30},
        "resources": {
            "energy": 9500,
            "minerals": 7200,
            "food": 8100,
            "research": 12000
        },
        "trust_matrix": {},
        "threat_assessment": {}
    }'::jsonb,
    5,
    'active',
    CURRENT_TIMESTAMP
);

