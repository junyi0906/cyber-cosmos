    '{
        "ideology": "militaristic_expansion",
        "population": 120000000000,
        "military_power": 92,
        "economic_power": 65,
        "technology_focus": "weapons_systems",
        "home_system": "Vorthan Major",
        "government_type": "imperial_dynasty",
        "primary_values": ["strength", "honor", "conquest"],
        "trust_base": 0.25,
        "threat_tolerance": 0.8,
        "expansion_drive": 0.95,
        "color": "#D94A4A",
        "symbol": "iron_crown"
    }'::jsonb,
    38,
    'active',
    NOW()
) ON CONFLICT DO NOTHING;

