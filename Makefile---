# Cyber-Cosmos Makefile
# Infrastructure and development commands

.PHONY: help infra-up infra-down infra-logs infra-status infra-clean \
        dev test build clean

# Default target
help:
	@echo "Cyber-Cosmos - Available Commands:"
	@echo ""
	@echo "Infrastructure:"
	@echo "  infra-up       Start all infrastructure services"
	@echo "  infra-down     Stop all infrastructure services"
	@echo "  infra-logs     View infrastructure logs"
	@echo "  infra-status   Check infrastructure status"
	@echo "  infra-clean    Remove all infrastructure data (WARNING: destructive)"
	@echo ""
	@echo "Development:"
	@echo "  dev            Start development environment"
	@echo "  test           Run tests"
	@echo "  build          Build production artifacts"
	@echo "  clean          Clean build artifacts"
	@echo ""

# Infrastructure Management
infra-up:
	@echo "🚀 Starting Cyber-Cosmos infrastructure..."
	@if [ ! -f deployments/.env ]; then \
		cp deployments/.env.example deployments/.env; \
		echo "📝 Created .env file from template"; \
	fi
	cd deployments && docker-compose up -d
	@echo "⏳ Waiting for services to be healthy..."
	@sleep 5
	@$(MAKE) infra-status

infra-down:
	@echo "🛑 Stopping Cyber-Cosmos infrastructure..."
	cd deployments && docker-compose down
	@echo "✅ Infrastructure stopped"

infra-logs:
	cd deployments && docker-compose logs -f

infra-status:
	@echo "📊 Infrastructure Status:"
	@echo ""
	@docker ps --filter "name=cyber-cosmos" --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" 2>/dev/null || echo "No containers running"
	@echo ""

infra-clean:
	@echo "⚠️  WARNING: This will remove all infrastructure data!"
	@read -p "Are you sure? (y/N): " confirm; \
	if [ "$$confirm" = "y" ] || [ "$$confirm" = "Y" ]; then \
		cd deployments && docker-compose down -v; \
		echo "✅ All infrastructure data removed"; \
	else \
		echo "❌ Operation cancelled"; \
	fi

# Development
dev:
	@echo "🔧 Starting development environment..."
	@echo "Run 'make infra-up' first if infrastructure is not running."

test:
	@echo "🧪 Running tests..."
	python -m pytest tests/ -v

build:
	@echo "📦 Building artifacts..."
	python -m pip install -r requirements.txt

clean:
	@echo "🧹 Cleaning build artifacts..."
	find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true
	find . -type d -name "*.egg-info" -exec rm -rf {} + 2>/dev/null || true
	find . -type f -name "*.pyc" -delete 2>/dev/null || true
	@echo "✅ Clean complete"